export default async function handler(req, res) {
  try {
    const { linkProduto, linkAfiliado } = req.query;

    const origem = linkProduto || linkAfiliado;
    if (!origem) {
      return res.status(400).json({ error: "Informe o link do anúncio ou o link de afiliado." });
    }

    let urlFinal = origem;
    let html = "";

    try {
      const resposta = await fetch(origem, {
        method: "GET",
        redirect: "follow",
        headers: { "user-agent": "Mozilla/5.0" }
      });
      urlFinal = resposta.url || origem;
      html = await resposta.text();
    } catch (e) {
      urlFinal = origem;
    }

    let match = String(urlFinal).match(/MLB-?\d+/i);
    if (!match && html) match = html.match(/MLB-?\d+/i);

    if (!match) {
      return res.status(400).json({
        error: "Não encontrei o código MLB. Use o link completo do anúncio no campo 'Link do anúncio'."
      });
    }

    const itemId = match[0].replace("-", "").toUpperCase();

    const itemRes = await fetch(`https://api.mercadolibre.com/items/${itemId}`);
    const item = await itemRes.json();

    if (!item || item.error) {
      return res.status(404).json({ error: "Produto não encontrado no Mercado Livre." });
    }

    const imagens = (item.pictures || [])
      .map(p => p.secure_url || p.url)
      .filter(Boolean);

    let categoriaNome = item.category_id || "Mercado Livre";

    try {
      const catRes = await fetch(`https://api.mercadolibre.com/categories/${item.category_id}`);
      const cat = await catRes.json();
      if (cat && cat.name) categoriaNome = cat.name;
    } catch (e) {}

    return res.status(200).json({
      itemId,
      nome: item.title || "",
      preco: item.price || 0,
      categoria: categoriaNome,
      imagens,
      linkCompra: linkAfiliado || origem,
      linkProduto: urlFinal,
      ativo: item.status === "active",
      estoque: item.available_quantity || 0,
      permalink: item.permalink || urlFinal
    });

  } catch (e) {
    return res.status(500).json({
      error: "Erro ao importar produto.",
      details: String(e)
    });
  }
}
